<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.ImageView?>

<BorderPane fx:id="rootBorderPane" styleClass="chat-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox>
            <ToolBar styleClass="chat-header-bar">
                <ImageView fx:id="conversationIconImage" fitHeight="34.0" fitWidth="34.0" preserveRatio="true" styleClass="chat-header-mark"/>
                <VBox spacing="1.0">
                    <Label text="Conversation" styleClass="chat-header-title"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearChatButton" styleClass="chat-toolbar-button"/>
            </ToolBar>
            <HBox styleClass="chat-session-info-bar">
                <Label fx:id="todoInfoLabel" text="Todos 0" styleClass="chat-session-chip"/>
                <Button fx:id="openTodosButton" text="Open Todos" styleClass="chat-toolbar-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Enter send / Shift+Enter line break / Cmd+Enter send" styleClass="chat-hint-label"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="6.0">
            <ScrollPane fx:id="messagesScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="chat-message-list-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="messagesContainer" styleClass="chat-message-list"/>
                </content>
            </ScrollPane>
            <HBox styleClass="chat-runtime-status-row">
                <HBox fx:id="assistantBusyContainer" styleClass="chat-busy-wrap" managed="false" visible="false">
                    <Label fx:id="assistantBusyLabel" text="Idle" styleClass="chat-busy-label"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </center>
    <bottom>
        <VBox styleClass="chat-composer-wrap">
            <HBox styleClass="chat-composer">
                <TextArea fx:id="inputTextField" promptText="Ask Visual Agent" wrapText="true" prefRowCount="2" HBox.hgrow="ALWAYS" styleClass="chat-input"/>
                <Button fx:id="sendButton" styleClass="chat-send-button"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
