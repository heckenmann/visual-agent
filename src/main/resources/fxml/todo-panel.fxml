<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="rootBorderPane" styleClass="todo-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="10.0" styleClass="todo-header">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <VBox spacing="2.0">
                    <Label text="Todos" styleClass="page-title"/>
                    <Label text="Tasks shared by the user, main agent, and sub-agents." styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addButton" styleClass="button-icon, accent">
                    <graphic>
                        <FontIcon iconLiteral="fas-plus"/>
                    </graphic>
                    <tooltip><Tooltip text="New todo"/></tooltip>
                </Button>
                <Button fx:id="editButton" styleClass="button-icon">
                    <graphic>
                        <FontIcon iconLiteral="fas-pen"/>
                    </graphic>
                    <tooltip><Tooltip text="Edit todo"/></tooltip>
                </Button>
                <Button fx:id="completeAllButton" styleClass="button-icon">
                    <graphic>
                        <FontIcon iconLiteral="fas-check-double"/>
                    </graphic>
                    <tooltip><Tooltip text="Complete all todos"/></tooltip>
                </Button>
                <Button fx:id="deleteCompletedButton" styleClass="button-icon">
                    <graphic>
                        <FontIcon iconLiteral="fas-trash"/>
                    </graphic>
                    <tooltip><Tooltip text="Delete completed todos"/></tooltip>
                </Button>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="todo-summary-row">
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Total" styleClass="text-caption"/>
                    <Label fx:id="totalCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Open" styleClass="text-caption"/>
                    <Label fx:id="openCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Active" styleClass="text-caption"/>
                    <Label fx:id="inProgressCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Done" styleClass="text-caption"/>
                    <Label fx:id="doneCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Filter" styleClass="text-caption"/>
                <ComboBox fx:id="statusFilterSelector" prefWidth="120.0"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <StackPane>
            <ListView fx:id="todoListView" styleClass="todo-list">
            </ListView>
            <VBox fx:id="todoEmptyState" alignment="CENTER" spacing="8.0" styleClass="empty-state" visible="false" managed="false">
                <FontIcon iconLiteral="fas-clipboard-list" styleClass="empty-state-icon"/>
                <Label fx:id="todoEmptyTitleLabel" text="No todos yet" styleClass="empty-state-title"/>
                <Label fx:id="todoEmptyDescriptionLabel" text="Create a task yourself or let an agent create one." styleClass="empty-state-description"/>
                <Button fx:id="emptyAddButton" styleClass="button-icon, accent">
                    <graphic>
                        <FontIcon iconLiteral="fas-plus"/>
                    </graphic>
                    <tooltip><Tooltip text="Create first todo"/></tooltip>
                </Button>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
