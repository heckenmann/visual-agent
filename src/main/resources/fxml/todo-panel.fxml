<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="rootBorderPane" styleClass="todo-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="10.0" styleClass="todo-header">
            <padding>
                <Insets top="16.0" right="18.0" bottom="12.0" left="18.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <VBox spacing="2.0">
                    <Label text="Todos" styleClass="title-3"/>
                    <Label text="Tasks shared by the user, main agent, and sub-agents" styleClass="text-caption"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addButton" text="Add" styleClass="accent">
                    <graphic>
                        <FontIcon iconLiteral="fas-plus" iconSize="11"/>
                    </graphic>
                </Button>
                <Button fx:id="editButton" text="Edit">
                    <graphic>
                        <FontIcon iconLiteral="fas-pen" iconSize="11"/>
                    </graphic>
                </Button>
                <Button fx:id="completeAllButton" text="Complete All">
                    <graphic>
                        <FontIcon iconLiteral="fas-check-double" iconSize="11"/>
                    </graphic>
                </Button>
                <Button fx:id="deleteCompletedButton" text="Delete Done">
                    <graphic>
                        <FontIcon iconLiteral="fas-trash" iconSize="11"/>
                    </graphic>
                </Button>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="todo-summary-row">
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Total" styleClass="text-caption"/>
                    <Label fx:id="totalCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Open" styleClass="text-caption"/>
                    <Label fx:id="openCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Active" styleClass="text-caption"/>
                    <Label fx:id="inProgressCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="todo-summary-chip">
                    <Label text="Done" styleClass="text-caption"/>
                    <Label fx:id="doneCountLabel" text="0" styleClass="bold"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Filter" styleClass="text-caption"/>
                <ComboBox fx:id="statusFilterSelector" prefWidth="120.0"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ListView fx:id="todoListView" styleClass="todo-list">
        </ListView>
    </center>
</BorderPane>
