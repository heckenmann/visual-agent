<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane fx:id="rootBorderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <Label fx:id="titleLabel" text="Canvas" styleClass="title-4"/>
    </top>
    <center>
        <Canvas fx:id="canvas">
            <BorderPane.margin>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </BorderPane.margin>
        </Canvas>
    </center>
</BorderPane>