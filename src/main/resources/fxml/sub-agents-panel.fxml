<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="rootVBox" styleClass="page-root, subagents-panel" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="2.0">
            <Label fx:id="titleLabel" text="Agents" styleClass="page-title"/>
            <Label text="Create specialized workers and monitor their current workload." styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAddAgent" text="New agent" styleClass="accent, primary-action">
            <graphic>
                <FontIcon iconLiteral="fas-plus" iconSize="11"/>
            </graphic>
        </Button>
    </HBox>
    <HBox spacing="10.0" styleClass="agent-summary-bar">
        <Label fx:id="agentCountLabel" text="0 agents" styleClass="summary-pill"/>
        <Label fx:id="activeJobsLabel" text="0 active jobs" styleClass="summary-pill, summary-pill-accent"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Parallel jobs are limited by Session settings." styleClass="field-help"/>
    </HBox>
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll" VBox.vgrow="ALWAYS">
        <StackPane>
            <VBox fx:id="agentsContainer" spacing="12.0" styleClass="agent-grid">
                <padding>
                    <Insets top="18.0" right="22.0" bottom="22.0" left="22.0"/>
                </padding>
            </VBox>
            <VBox fx:id="emptyState" alignment="CENTER" spacing="8.0" styleClass="empty-state" visible="false" managed="false">
                <FontIcon iconLiteral="fas-users" iconSize="28" styleClass="empty-state-icon"/>
                <Label text="No agents configured" styleClass="empty-state-title"/>
                <Label text="Create an agent to delegate specialized work." styleClass="empty-state-description"/>
                <Button fx:id="emptyCreateAgentButton" text="Create first agent" styleClass="accent, primary-action">
                    <graphic>
                        <FontIcon iconLiteral="fas-plus" iconSize="11"/>
                    </graphic>
                </Button>
            </VBox>
        </StackPane>
    </ScrollPane>
</VBox>
