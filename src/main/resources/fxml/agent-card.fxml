<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<VBox spacing="6.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
  <HBox spacing="8.0" styleClass="agent-header">
    <Label fx:id="nameLabel" styleClass="agent-name" />
    <Label fx:id="statusIndicator" styleClass="agent-status-indicator" />
  </HBox>
  <Label fx:id="roleLabel" />
  <Label fx:id="jobsLabel" styleClass="agent-job-count" />
  <Label fx:id="taskLabel" wrapText="true" />
  <Separator />
  <HBox spacing="8.0">
    <Button fx:id="btnConfigure" text="Configure" />
    <Button fx:id="btnRun" text="Run" />
    <Button fx:id="btnLogs" text="Logs" />
    <Button fx:id="btnDelete" text="Delete" />
  </HBox>
</VBox>
