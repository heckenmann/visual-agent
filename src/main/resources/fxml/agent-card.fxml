<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox fx:id="root" spacing="10.0" styleClass="agent-card" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
  <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="agent-header">
    <Label fx:id="statusIndicator" styleClass="agent-status-indicator" />
    <VBox spacing="1.0" HBox.hgrow="ALWAYS">
      <Label fx:id="nameLabel" styleClass="agent-name" />
      <Label fx:id="roleLabel" styleClass="agent-role" />
    </VBox>
    <Label fx:id="jobsLabel" styleClass="agent-job-count" />
  </HBox>
  <VBox spacing="4.0" styleClass="agent-task-box">
    <Label text="CURRENT TASK" styleClass="agent-task-caption"/>
    <Label fx:id="taskLabel" text="Waiting for work" wrapText="true" styleClass="agent-task"/>
  </VBox>
  <Separator />
  <HBox spacing="8.0" alignment="CENTER_LEFT">
    <Button fx:id="btnRun" text="Run next todo" styleClass="accent">
      <graphic><FontIcon iconLiteral="fas-play" iconSize="10"/></graphic>
    </Button>
    <Button fx:id="btnConfigure" text="Configure" />
    <Button fx:id="btnLogs" text="Logs" />
    <Region HBox.hgrow="ALWAYS"/>
    <Button fx:id="btnDelete" styleClass="button-icon, danger-button">
      <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="10"/></graphic>
    </Button>
  </HBox>
</VBox>
