<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" styleClass="agent-view" spacing="4.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label fx:id="statusIndicator" styleClass="agent-status-indicator" />
                <VBox>
                    <children>
                        <Label fx:id="nameLabel" styleClass="bold" />
                        <Label fx:id="roleLabel" styleClass="text-muted, text-caption" />
                        <Label fx:id="jobsLabel" styleClass="text-caption" />
                    </children>
                </VBox>
            </children>
        </HBox>
        <Label fx:id="taskLabel" styleClass="text-caption" wrapText="true" />
    </children>
</VBox>
